{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/human-verdict-record-v2.json",
  "title": "Human Verdict Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "pullRequestNumber",
    "headSha",
    "recordedAt",
    "accountableOwner",
    "verdict",
    "humanExplanation",
    "mostCredibleFailureMode",
    "detection",
    "containmentOrRollback",
    "evidenceReliedUpon",
    "evidenceLimitations",
    "riskMapRef",
    "riskDispositions",
    "residualRisk",
    "rationale",
    "conditions"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0" },
    "repository": { "type": "string", "minLength": 1 },
    "pullRequestNumber": { "type": "integer", "minimum": 1 },
    "headSha": { "type": "string", "pattern": "^[0-9a-fA-F]{40}$" },
    "recordedAt": { "type": "string", "format": "date-time" },
    "accountableOwner": { "type": "string", "minLength": 1 },
    "verdict": {
      "enum": [
        "approve",
        "approve-with-conditions",
        "redirect",
        "block",
        "defer"
      ]
    },
    "humanExplanation": { "type": "string", "minLength": 1 },
    "mostCredibleFailureMode": { "type": "string", "minLength": 1 },
    "detection": { "type": "string", "minLength": 1 },
    "containmentOrRollback": { "type": "string", "minLength": 1 },
    "evidenceReliedUpon": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidenceLimitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "riskMapRef": { "type": "string", "minLength": 1 },
    "riskDispositions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "riskId",
          "disposition",
          "rationale",
          "conditions"
        ],
        "properties": {
          "riskId": { "type": "string", "minLength": 1 },
          "disposition": {
            "enum": [
              "remediated",
              "accepted",
              "accepted-with-conditions",
              "deferred-and-tracked",
              "rejected-as-unsupported",
              "redirected",
              "blocked-pending-evidence",
              "blocked-pending-specialist-review"
            ]
          },
          "rationale": { "type": "string", "minLength": 1 },
          "conditions": {
            "type": "array",
            "items": { "$ref": "#/$defs/condition" }
          },
          "owner": { "type": ["string", "null"] },
          "reviewPoint": { "type": ["string", "null"] },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "residualRisk": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "reviewOrExpiryPoint": { "type": ["string", "null"] },
    "specialistApprovals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "sourcePacket": { "type": ["string", "null"] },
    "technicalReviewRef": { "type": ["string", "null"] }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "status"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "status": { "enum": ["open", "satisfied", "waived"] },
        "evidence": { "type": "string" }
      }
    }
  }
}